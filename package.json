{
  "name": "q-gagarin",
  "version": "1.0.0",
  "description": "Upbit API Node.js playground.",
  "private": true,
  "main": "index.js",
  "scripts": {
    "ticker": "node src/rest/ticker.js",
    "ticker:ws": "node src/ws/ticker.js",
    "triangles": "node scripts/scan-triangles.js",
    "triangles:live": "node scripts/deprecated-browser-dashboard.js",
    "engine": "node scripts/run-engine.js",
    "cli": "node scripts/qg-cli.js",
    "cli:watch": "node scripts/qg-cli.js /watch",
    "cli:logs": "node scripts/qg-cli.js /logs --follow",
    "cli:desk": "node scripts/qg-cli.js /desk --watch",
    "dashboard": "node scripts/deprecated-browser-dashboard.js",
    "replay:dryrun": "node scripts/replay-dryrun.js",
    "baseline": "node scripts/benchmark-live-baseline.js",
    "check": "find src scripts test -name '*.js' -print0 | xargs -0 -n1 node --check",
    "test": "npm run check && node --test"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Moon-Young-Choi/q-gagarin.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Moon-Young-Choi/q-gagarin/issues"
  },
  "homepage": "https://github.com/Moon-Young-Choi/q-gagarin#readme",
  "dependencies": {
    "axios": "^1.18.1",
    "ws": "^8.21.0"
  }
}
